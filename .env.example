# Copier ce fichier en .env et remplir les valeurs
# Ne jamais commiter le .env — il est dans .gitignore

APP_ENV=development
APP_VERSION=1.0.0
PORT=3001

# Redis — en Docker Compose, utiliser le nom du service "cache"
# En local sans Docker, utiliser redis://127.0.0.1:6379
REDIS_URL=redis://cache:6379
